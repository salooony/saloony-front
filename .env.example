# ============================================================
# HOW TO USE
# ------------------------------------------------------------
# Linux / Mac / VS Code Terminal or any Editor Terminal:
#       cp .env.example .env
#
# Windows (PowerShell):
#       Copy-Item .env.example .env
#
# Then fill in the values marked with <your-...>
# Never commit your .env file — it is gitignored
# ============================================================

## Version
NEXT_PUBLIC_VERSION=v3.5.1
GENERATE_SOURCEMAP=false

## Backend API URL
NEXT_PUBLIC_API_URL=<your-api-url>

## Google Map Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<your-google-maps-api-key>

## Map Box
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=<your-mapbox-access-token>

## App Port (used by Docker and Next.js dev server)
PORT=3000

## Next Auth
NEXT_PUBLIC_AUTH_URL=http://localhost:3002/
## NextAuth uses this server-side to build OAuth callback URLs—keep it in sync with the deployed domain.
NEXTAUTH_URL=http://localhost:3000/
NEXTAUTH_SECRET=<your-nextauth-secret>

## Auth0
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_CLIENT_SECRET=
NEXT_PUBLIC_AUTH0_DOMAIN=

## Cognito
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_CLIENT_SECRET=
NEXT_PUBLIC_COGNITO_REGION=
NEXT_PUBLIC_COGNITO_POOL_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=

## JWT
## for 1 day - 86400 = 1 * 24 * 60 * 60
NEXT_PUBLIC_JWT_TIMEOUT=86400
JWT_SECRET=<your-jwt-secret>

## Google OAuth
NEXT_PUBLIC_AUTH_GOOGLE_ID=<your-google-client-id>
AUTH_GOOGLE_CLIENT_SECRET=<your-google-client-secret>

## Facebook OAuth
NEXT_PUBLIC_AUTH_FACEBOOK_ID=<your-facebook-app-id>
AUTH_FACEBOOK_CLIENT_SECRET=<your-facebook-client-secret>
