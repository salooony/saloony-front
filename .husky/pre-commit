#!/bin/bash

# Get the current branch name
branch_name=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
echo "Current branch: $branch_name"

# Validate branch name format and extract ticket number if applicable
if [[ $branch_name =~ ^develop$ ]]; then
  echo "On develop branch. No ticket number needed."
  exit 0
elif [[ $branch_name =~ ^(feature|bugfix|hotfix)/([A-Z]+-[0-9]+) ]]; then
  ticket_number=${BASH_REMATCH[2]}
  echo "Extracted ticket number: $ticket_number"
else
  echo "Invalid branch name format. Use 'develop' or '{type}/TICKET-123' format."
  exit 1
fi
